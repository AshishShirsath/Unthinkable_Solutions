# ============================================================
#   Rent & Flatmate Finder — Environment Variables Template
#   Copy this file to .env and fill in your actual values.
#   NEVER commit .env to version control.
# ============================================================

# ────────────────────────────────────────────────────────────
# DATABASE (MySQL on AWS EC2)
# ────────────────────────────────────────────────────────────
DB_HOST=13.234.48.249
DB_PORT=3306
DB_NAME=rent_flatmate_finder
DB_USERNAME=rentuser
DB_PASSWORD=1234

# ────────────────────────────────────────────────────────────
# JWT AUTHENTICATION
# ────────────────────────────────────────────────────────────
# Minimum 32-character random hex string
JWT_SECRET=9VQz6XoW9lq3x2pJ8uR4sK7nB5mY1cD8fH2aL6wX3zQ9vE4tN7pR5uK1jM8sC2yF
# Access token expiry in milliseconds (default: 15 minutes)
JWT_ACCESS_TOKEN_EXPIRATION=900000
# Refresh token expiry in milliseconds (default: 7 days)
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# ────────────────────────────────────────────────────────────
# OPENAI (LLM Compatibility Scoring)
# ────────────────────────────────────────────────────────────
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=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
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# ────────────────────────────────────────────────────────────
# MAIL (Gmail SMTP)
# ────────────────────────────────────────────────────────────
# Use a Gmail App Password (NOT your real Gmail password)
# Generate one at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password

# ────────────────────────────────────────────────────────────
# APPLICATION
# ────────────────────────────────────────────────────────────
# Frontend origin for CORS
FRONTEND_URL=http://localhost:4200
SERVER_PORT=8080

# ────────────────────────────────────────────────────────────
# ADMIN USER (auto-seeded on first boot)
# ────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@rentflatmatefinder.com
ADMIN_PASSWORD=Admin123!
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
